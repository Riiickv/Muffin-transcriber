<Page
    x:Class="MuffinTranscriber.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:MuffinTranscriber"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    NavigationCacheMode="Required"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="24,24,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,24"
            Style="{ThemeResource TitleTextBlockStyle}"
            Text="{x:Bind local:AppStrings.History_Title}" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" x:Name="ListColumn" MinWidth="200" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- Left Pane: List of history items and custom prompt -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ListView
                    x:Name="HistoryListView"
                    Grid.Row="0"
                    SelectionChanged="HistoryListView_SelectionChanged"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:TranscriptionHistoryItem">
                            <Grid Padding="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{x:Bind SourceFileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind TimestampString}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <Button Grid.Column="1" Padding="8" Margin="4,0" ToolTipService.ToolTip="Rename" Click="RenameButton_Click" Tag="{x:Bind Id}">
                                    <FontIcon Glyph="&#xE8AC;" FontSize="14" />
                                </Button>
                                <Button Grid.Column="2" Padding="8" ToolTipService.ToolTip="Delete" Click="DeleteButton_Click" Tag="{x:Bind Id}">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="IndianRed" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <tk:GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" Height="12" />

                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind local:AppStrings.History_CustomPromptTitle}" Margin="0,0,0,4" />
                    <TextBox x:Name="HistoryCustomPromptBox"
                        Grid.Row="1"
                        PlaceholderText="{x:Bind local:AppStrings.History_CustomPromptPlaceholder}"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch" />
                </Grid>
            </Grid>

            <tk:GridSplitter Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Width="12" />

            <!-- Right Pane: Details -->
            <Border
                x:Name="DetailsPane"
                Grid.Column="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24"
                Visibility="Collapsed">
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Action Options -->
                    <Grid Grid.Row="0" ColumnSpacing="16" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Re-Transcribe Row -->
                        <Button
                            Grid.Row="0" Grid.Column="0"
                            x:Name="ReTranscribeButton"
                            Height="32" Width="130"
                            HorizontalAlignment="Stretch"
                            Style="{ThemeResource AccentButtonStyle}"
                            Click="ReTranscribeButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE720;" FontSize="14" />
                                <TextBlock Text="{x:Bind local:AppStrings.History_BtnReTranscribe}" />
                            </StackPanel>
                        </Button>
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="HistoryWhisperModelBox" HorizontalAlignment="Stretch" SelectedIndex="0" />
                        
                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind local:AppStrings.History_LanguageLabel}" VerticalAlignment="Bottom" />

                        <!-- Format/Summarize Row -->
                        <Grid Grid.Row="1" Grid.Column="0" ColumnSpacing="8" Width="130" HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                Grid.Column="0"
                                x:Name="ReformatButton"
                                Height="32"
                                HorizontalAlignment="Stretch"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="ReformatButton_Click"
                                ToolTipService.ToolTip="Format Transcript">
                                <FontIcon Glyph="&#xE70F;" FontSize="14" />
                            </Button>
                            <Button
                                Grid.Column="1"
                                x:Name="SummarizeButton"
                                Height="32"
                                HorizontalAlignment="Stretch"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="SummarizeButton_Click"
                                ToolTipService.ToolTip="Summarize Transcript">
                                <FontIcon Glyph="&#xE8F1;" FontSize="14" />
                            </Button>
                        </Grid>
                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="LLMModelBox" HorizontalAlignment="Stretch" SelectedIndex="0" />
                        <ComboBox Grid.Row="1" Grid.Column="2" x:Name="FormatLanguageBox" HorizontalAlignment="Stretch" SelectedIndex="0" />
                    </Grid>

                    <!-- Transcript Box -->
                    <Grid Grid.Row="2" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" x:Name="TranscriptTitle" Style="{ThemeResource BodyStrongTextBlockStyle}" Text="{x:Bind local:AppStrings.Home_TranscriptTitle}" VerticalAlignment="Center" />

                        <Grid Grid.Row="1">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                                <Button x:Name="TabRawButton" Content="{x:Bind local:AppStrings.Home_TabRaw}" Click="TabRawButton_Click" Style="{ThemeResource AccentButtonStyle}"/>
                                <Button x:Name="TabFormattedButton" Content="{x:Bind local:AppStrings.Home_TabFormatted}" Click="TabFormattedButton_Click" />
                                <Button x:Name="TabSummaryButton" Content="{x:Bind local:AppStrings.Home_TabSummary}" Click="TabSummaryButton_Click" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <DropDownButton x:Name="ExportButton" Content="{x:Bind local:AppStrings.History_ExportBtn}">
                                    <DropDownButton.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="{x:Bind local:AppStrings.History_ExportText}" Click="ExportText_Click" />
                                            <MenuFlyoutItem Text="{x:Bind local:AppStrings.History_ExportSrt}" Click="ExportSrt_Click" />
                                            <MenuFlyoutItem Text="{x:Bind local:AppStrings.History_ExportVtt}" Click="ExportVtt_Click" />
                                        </MenuFlyout>
                                    </DropDownButton.Flyout>
                                </DropDownButton>
                                <Button x:Name="CopyFormattedButton" Click="CopyFormattedButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                        <TextBlock Text="{x:Bind local:AppStrings.Home_CopyButton}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                        <TextBox
                            Grid.Row="2"
                            x:Name="TranscriptBox"
                            IsReadOnly="True"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            VerticalAlignment="Stretch"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </Grid>

                </Grid>
            </Border>
            
            <TextBlock
                x:Name="EmptyDetailsText"
                Grid.Column="2"
                Text="{x:Bind local:AppStrings.History_EmptyDetailsText}"
                Style="{ThemeResource BodyTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
                
        </Grid>

        <!-- Floating Notification -->
        <InfoBar
            x:Name="StatusBar"
            Grid.Row="1"
            IsOpen="False"
            IsClosable="True"
            Severity="Informational"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,32">
            <InfoBar.Shadow>
                <ThemeShadow />
            </InfoBar.Shadow>
        </InfoBar>
    </Grid>
</Page>
