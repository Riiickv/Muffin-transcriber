<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MuffinTranscriber.Pages.RecordPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MuffinTranscriber"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled">
            <StackPanel
            MaxWidth="900"
            Padding="24,24,24,24"
            Spacing="18"
            HorizontalAlignment="Stretch">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="{x:Bind local:AppStrings.Record_Title}" />
                <ProgressRing
                    x:Name="BusyRing"
                    Grid.Column="1"
                    Width="24"
                    Height="24"
                    IsActive="False" />
            </Grid>

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="6">
                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind local:AppStrings.Home_LanguageLabel}" />
                            <ComboBox x:Name="LanguageBox" SelectedIndex="0" HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind local:AppStrings.Home_WhisperModelLabel}" />
                            <ComboBox
                                x:Name="WhisperModelBox"
                                HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <Button
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            x:Name="RecordButton"
                            MinHeight="68"
                            MinWidth="220"
                            CornerRadius="8"
                            Style="{StaticResource AccentButtonStyle}"
                            Background="Firebrick"
                            VerticalAlignment="Center"
                            Click="RecordButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon x:Name="RecordIcon" Glyph="&#xE720;" FontSize="24" Foreground="White" />
                                <TextBlock x:Name="RecordStatusText" Text="Start Recording" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White" />
                            </StackPanel>
                        </Button>
                        <TextBlock Grid.Column="1" HorizontalAlignment="Center" x:Name="RecordTimerText" Style="{StaticResource TitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="00:00:00" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right" x:Name="VisualizerPanel" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Height="40" Width="150" />
                    </Grid>

                </Grid>
            </Border>

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4" Margin="0,0,16,0">
                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind local:AppStrings.Home_CustomPromptLabel}" />
                        <TextBox x:Name="RecordCustomFormatBox"
                            PlaceholderText="Clean up punctuation and paragraphs with a local LLM."
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            Height="72" />
                    </StackPanel>

                    <Grid Grid.Column="1" RowSpacing="12" HorizontalAlignment="Right">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <ToggleSwitch x:Name="FormatSwitch" Header="{x:Bind local:AppStrings.Home_FormatSwitch}" />
                            <ToggleSwitch Grid.Column="1" x:Name="SummarizeSwitch" Header="{x:Bind local:AppStrings.Home_SummarizeSwitch}" />
                        </Grid>

                        <Grid Grid.Row="1" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="FormatterModelBox" HorizontalAlignment="Stretch" />
                            <ComboBox x:Name="FormatLanguageBox" Grid.Column="1" SelectedIndex="0" HorizontalAlignment="Stretch" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind local:AppStrings.Home_TranscriptTitle}" />
                    
                    <Grid Grid.Row="1">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                            <Button x:Name="TabRawButton" Content="{x:Bind local:AppStrings.Home_TabRaw}" Click="TabRawButton_Click" Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="TabFormattedButton" Content="{x:Bind local:AppStrings.Home_TabFormatted}" Click="TabFormattedButton_Click" />
                            <Button x:Name="TabSummaryButton" Content="{x:Bind local:AppStrings.Home_TabSummary}" Click="TabSummaryButton_Click" />
                        </StackPanel>
                        <Button
                            HorizontalAlignment="Right"
                            Click="CopyButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                <TextBlock Text="{x:Bind local:AppStrings.Home_CopyButton}" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBox
                        x:Name="TranscriptBox"
                        Grid.Row="2"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        MinHeight="300"
                        HorizontalAlignment="Stretch"
                        PlaceholderText="Transcript will appear here." />
                </Grid>
            </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Floating Notification -->
        <InfoBar
            x:Name="StatusBar"
            IsOpen="False"
            IsClosable="True"
            Severity="Informational"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,32">
            <InfoBar.Shadow>
                <ThemeShadow />
            </InfoBar.Shadow>
        </InfoBar>
    </Grid>
</Page>
