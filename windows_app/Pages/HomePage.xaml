<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MuffinTranscriber.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MuffinTranscriber"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled">
            <StackPanel
            MaxWidth="900"
            Padding="24,24,24,24"
            Spacing="18"
            HorizontalAlignment="Stretch">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="{x:Bind local:AppStrings.Home_Title}" />
                <ProgressRing
                    x:Name="BusyRing"
                    Grid.Column="1"
                    Width="24"
                    Height="24"
                    IsActive="False" />
            </Grid>

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="6">
                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind local:AppStrings.Home_LanguageLabel}" />
                            <ComboBox x:Name="LanguageBox" SelectedIndex="0" HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind local:AppStrings.Home_WhisperModelLabel}" />
                            <ComboBox
                                x:Name="WhisperModelBox"
                                SelectionChanged="WhisperModelBox_SelectionChanged"
                                HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>

                        <Button
                            x:Name="FileButton"
                            MinHeight="68"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Click="FileButton_Click"
                            Content="{x:Bind local:AppStrings.Home_DropZoneText}" />

                        <Button
                            x:Name="TranscribeButton"
                            Grid.Column="1"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Click="TranscribeButton_Click"
                            Content="{x:Bind local:AppStrings.Home_TranscribeButton}"
                            IsEnabled="False" />
                    </Grid>

                </Grid>
            </Border>

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4" Margin="0,0,16,0">
                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind local:AppStrings.Home_CustomPromptLabel}" />
                        <TextBox x:Name="HomeCustomFormatBox"
                            PlaceholderText="Clean up punctuation and paragraphs with a local LLM."
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            Height="72"
                            TextChanged="HomeCustomFormatBox_TextChanged" />
                    </StackPanel>

                    <Grid Grid.Column="1" RowSpacing="12" HorizontalAlignment="Right">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <ToggleSwitch x:Name="FormatSwitch" Header="{x:Bind local:AppStrings.Home_FormatSwitch}" />
                            <ToggleSwitch Grid.Column="1" x:Name="SummarizeSwitch" Header="{x:Bind local:AppStrings.Home_SummarizeSwitch}" />
                        </Grid>

                        <Grid Grid.Row="1" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="FormatterModelBox" HorizontalAlignment="Stretch" />
                            <ComboBox x:Name="FormatLanguageBox" Grid.Column="1" SelectedIndex="0" HorizontalAlignment="Stretch" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind local:AppStrings.Home_TranscriptTitle}" />
                    
                    <Grid Grid.Row="1">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                            <Button x:Name="TabRawButton" Content="{x:Bind local:AppStrings.Home_TabRaw}" Click="TabRawButton_Click" Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="TabFormattedButton" Content="{x:Bind local:AppStrings.Home_TabFormatted}" Click="TabFormattedButton_Click" />
                            <Button x:Name="TabSummaryButton" Content="{x:Bind local:AppStrings.Home_TabSummary}" Click="TabSummaryButton_Click" />
                        </StackPanel>
                        <Button
                            HorizontalAlignment="Right"
                            Click="CopyButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                <TextBlock Text="{x:Bind local:AppStrings.Home_CopyButton}" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBox
                        x:Name="TranscriptBox"
                        Grid.Row="2"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        MinHeight="300"
                        HorizontalAlignment="Stretch"
                        PlaceholderText="Transcript will appear here." />
                </Grid>
            </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Floating Notification -->
        <InfoBar
            x:Name="StatusBar"
            IsOpen="False"
            IsClosable="True"
            Severity="Informational"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,32">
            <InfoBar.Shadow>
                <ThemeShadow />
            </InfoBar.Shadow>
        </InfoBar>
    </Grid>
</Page>
